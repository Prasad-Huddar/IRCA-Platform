--

CREATE FUNCTION public.create_daily_log(user_id_input text, addiction_type_input text, log_date_input text, sobriety_status_input boolean, relapse_occurred_input boolean DEFAULT false, relapse_triggers_input text[] DEFAULT NULL::text[], relapse_notes_input text DEFAULT NULL::text) RETURNS uuid
    LANGUAGE plpgsql SECURITY DEFINER
    SET search_path TO 'public', 'extensions'
    AS $$
DECLARE
  new_id UUID;
  u_id UUID;
  l_date DATE;
BEGIN
  -- Cast inputs
  u_id := user_id_input::UUID;
  l_date := log_date_input::DATE;

  INSERT INTO daily_tracking_log (
    user_id,
    addiction_type,
    log_date,
    sobriety_status,
    relapse_occurred,
    relapse_triggers,
    relapse_notes
  )
  VALUES (
    u_id,
    addiction_type_input,
    l_date,
    sobriety_status_input,
    relapse_occurred_input,
    relapse_triggers_input,
    relapse_notes_input
  )
  RETURNING id INTO new_id;

  RETURN new_id;
END;
$$;


