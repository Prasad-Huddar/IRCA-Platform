    user_id,
    addiction_type,
    start_date,
    is_active,
    current_streak_days,
    longest_streak_days,
    total_sobriety_days,
    relapses_count,
    daily_cost
  )
  VALUES (
    u_id,
    addiction_type_input,
    s_date,
    true,
    0,
    0,
    0,
    0,
    daily_cost_input
  )
  RETURNING id INTO new_id;

  RETURN new_id;
END;
$$;


